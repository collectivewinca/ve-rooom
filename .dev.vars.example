# Cloudflare account
CF_ACCOUNT_ID=your_account_id
CF_API_TOKEN=your_api_token_with_realtime_admin

# RealtimeKit app
RTK_APP_ID=your_realtimekit_app_id

# R2 storage config (for recording_config.storage_config in rooms.ts)
# Set via `npx wrangler pages secret put R2_ACCESS_KEY --project-name ve-rooom`
R2_ACCESS_KEY=your_r2_access_key
R2_SECRET_KEY=your_r2_secret_key
# Bucket name is non-secret — also in wrangler.toml [vars]
R2_BUCKET=ve-room

# Ollama Cloud (wire later — not needed for Phases 0-4)
# Base URL: https://ollama.com for Ollama Cloud, or http://localhost:11434 for local
OLLAMA_API_KEY=your_ollama_cloud_key
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_MODEL=llama3.1:8b